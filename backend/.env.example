# Скопіюй у .env і заповни
ANTHROPIC_API_KEY=sk-ant-...

# Модель Claude (за замовчуванням найкраща)
CLAUDE_MODEL=claude-opus-4-8

# CORS — звідки дозволені запити (для розробки)
ALLOWED_ORIGINS=*

# MongoDB
# Локально (docker-compose.local.yml) це задається автоматично (mongodb://mongo:27017).
# На Dokploy встав внутрішній connection URL з Mongo-сервісу.
MONGO_URL=mongodb://localhost:27017
MONGO_DB=ai_sport
